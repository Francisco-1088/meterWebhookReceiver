# Teams destinations (JSON array). Managed via the UI — no need to hand-edit.
# Each entry: {"id": "<uuid>", "name": "<label>", "url": "<webhook URL>"}
# Example:
#   TEAMS_DESTINATIONS=[{"id":"abc","name":"Ops","url":"https://..."}]
TEAMS_DESTINATIONS=

# Legacy single-URL config — read only if TEAMS_DESTINATIONS is empty.
# Kept for back-compat; on first save via the UI it is migrated into TEAMS_DESTINATIONS.
TEAMS_WEBHOOK_URL=

# Optional: Meter webhook signing secret for request verification
# Set this if Meter provides a signing secret for your webhook endpoint
METER_WEBHOOK_SECRET=

# Server bind settings
HOST=0.0.0.0
PORT=8000